# unGhost — environment variable template.
# Copy to `.env.local` for dev, set in Cloudflare Container env for staging/prod.
# Empty values trigger the in-app mock adapter so the dev experience is
# offline-friendly. Set a value to flip the adapter to live mode.

# ── Core ────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_VERSION=dev
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
DEPLOY_REGION=local
LOG_LEVEL=debug

# ── Database ────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://noghost:noghost@127.0.0.1:27018/noghost?authSource=admin
CRON_SECRET=replace-me-in-prod

# ── Redis (Upstash) — empty falls back to in-memory mock ────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── AI ──────────────────────────────────────────────────────────────────
# Provider priority: GROQ_API_KEY (primary, low-latency) >
# GOOGLE_AI_API_KEY (fallback, stricter JSON schema) >
# ANTHROPIC_API_KEY (secondary fallback) > mock.
# Each provider catches its own failures and chains down to the next.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ── Email (Resend) ──────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=

# ── Payments (PhonePe) ──────────────────────────────────────────────────
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1
PHONEPE_BASE_URL=

# ── Realtime (Pusher Channels) ──────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap2

# ── Background jobs (Inngest) ───────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Object storage (Cloudflare R2) ──────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# ── Live video (100ms) ─────────────────────────────────────────────────
HMS_ACCESS_KEY=
HMS_APP_SECRET=
HMS_TEMPLATE_ID=
HMS_REGION=in

# ── Observability ───────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Slack alerts ────────────────────────────────────────────────────────
SLACK_WEBHOOK_ENGINEERING=
SLACK_WEBHOOK_PROD=
SLACK_WEBHOOK_INCIDENTS=

# ── OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
